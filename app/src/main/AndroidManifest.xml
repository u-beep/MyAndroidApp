<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================ -->
    <!-- 权限声明（在application标签上方）             -->
    <!-- 普通权限：安装时自动授权，不用动态申请        -->
    <!-- 危险权限：运行时弹窗让用户手动授权            -->
    <!-- ============================================ -->

    <!-- 读取外部存储（Android 6~12适用） -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <!-- 写入外部存储（Android 6~12适用） -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <!-- Android 13+读取图片专用权限（取代上面两个） -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- 网络权限（OkHttp网络请求必须） -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- ============================================ -->
    <!-- application：整个APP的全局配置，只能有一个      -->
    <!-- ============================================ -->
    <application
        android:name=".MyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.MyApplication">

        <!-- 登录页面 -->
        <!-- android:name=Activity类名，.代表当前包名 -->
        <!-- android:exported=true 允许外部调用（启动页必须true） -->
        <!-- android:screenOrientation=portrait 永远竖屏 -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
            <intent-filter>
                <!-- android.intent.action.MAIN=标记为APP入口 -->
                <!-- android.intent.category.LAUNCHER=出现在桌面应用列表 -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 主页面（singleTask：栈内唯一，跳转时清空上层页面） -->
        <activity
            android:name=".MainActivity"
            android:launchMode="singleTask"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 注册页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 修改密码页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".ChangePwdActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 备忘录页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MemoActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 备忘录编辑页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MemoEditActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 设置页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".SettingActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- SQLite备忘录列表页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MemoListActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- SQLite备忘录编辑页面 -->
        <activity
            android:name=".EditMemoActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 详情页面（singleTop：栈顶复用，演示5种Intent传值） -->
        <activity
            android:name=".DetailActivity"
            android:launchMode="singleTop"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 新闻详情页面 -->
        <activity
            android:name=".NewsDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

    </application>

</manifest>
