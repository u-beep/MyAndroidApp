<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================ -->
    <!-- application：整个APP的全局配置，只能有一个      -->
    <!-- ============================================ -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- 登录页面 -->
        <!-- android:name=Activity类名，.代表当前包名 -->
        <!-- android:exported=true 允许外部调用（启动页必须true） -->
        <!-- android:screenOrientation=portrait 永远竖屏 -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
            <intent-filter>
                <!-- android.intent.action.MAIN=标记为APP入口 -->
                <!-- android.intent.category.LAUNCHER=出现在桌面应用列表 -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 主页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 注册页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 修改密码页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".ChangePwdActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 备忘录页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MemoActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

        <!-- 备忘录编辑页面 -->
        <!-- android:exported=false 不允许外部调用（仅APP内部跳转） -->
        <activity
            android:name=".MemoEditActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication"
            android:screenOrientation="portrait">
        </activity>

    </application>

</manifest>
