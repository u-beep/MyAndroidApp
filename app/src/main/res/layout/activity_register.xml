<?xml version="1.0" encoding="utf-8"?>
<!-- 注册页面布局：ConstraintLayout约束布局，风格与登录页统一 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".RegisterActivity">

    <!--
        注册账号输入框
        hint        = 输入框为空时显示的灰色提示文字
        digits      = 限制只能输入字母和数字
        padding     = 内边距12dp
        constraintWidth_percent = 宽度占父布局的90%
    -->
    <EditText
        android:id="@+id/et_account"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请输入注册账号"
        android:padding="12dp"
        android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="120dp" />

    <!--
        注册密码输入框
        inputType   = textPassword 输入内容显示成小圆点
        maxLength   = 最多12个字符
    -->
    <EditText
        android:id="@+id/et_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请输入密码"
        android:inputType="textPassword"
        android:maxLength="12"
        android:padding="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_account"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp" />

    <!--
        确认密码输入框
        inputType   = textPassword 输入内容显示成小圆点
        maxLength   = 最多12个字符
    -->
    <EditText
        android:id="@+id/et_pwd2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请确认密码"
        android:inputType="textPassword"
        android:maxLength="12"
        android:padding="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp" />

    <!--
        完成注册按钮
        backgroundTint  = 绿色#4CAF50（注册用绿色区分登录蓝色）
        cornerRadius    = 圆角12dp，与登录按钮风格统一
    -->
    <Button
        android:id="@+id/btn_register"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="完成注册"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_pwd2"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
