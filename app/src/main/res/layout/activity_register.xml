<?xml version="1.0" encoding="utf-8"?>
<!-- 注册页面：ScrollView滚动布局 + Style样式 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 注册账号（用 MyEditText 样式简化） -->
        <EditText
            android:id="@+id/et_account"
            style="@style/MyEditText"
            android:hint="请输入注册账号"
            android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ" />

        <!-- 注册密码（用 MyPasswordInput 样式简化） -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_pwd"
            style="@style/MyPasswordInput">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_pwd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入密码"
                android:inputType="textPassword"
                android:maxLength="12"
                android:padding="12dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 确认密码（用 MyPasswordInput 样式简化） -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_pwd2"
            style="@style/MyPasswordInput">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_pwd2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请确认密码"
                android:inputType="textPassword"
                android:maxLength="12"
                android:padding="12dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 性别单选 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择性别："
            android:textSize="16sp"
            android:layout_marginTop="15dp" />

        <RadioGroup
            android:id="@+id/rg_sex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">

            <RadioButton
                android:id="@+id/rb_man"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="男"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_woman"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="女"
                android:layout_marginStart="30dp" />
        </RadioGroup>

        <!-- 爱好多选 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择爱好："
            android:textSize="16sp"
            android:layout_marginTop="15dp" />

        <CheckBox
            android:id="@+id/cb_ball"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打篮球"
            android:layout_marginTop="5dp" />

        <CheckBox
            android:id="@+id/cb_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="看书" />

        <CheckBox
            android:id="@+id/cb_game"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="玩游戏" />

        <!-- 注册按钮（用 MyButton 样式简化） -->
        <Button
            android:id="@+id/btn_register"
            style="@style/MyButton"
            android:text="完成注册"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="25dp" />

        <!-- 加载动画（注册时显示） -->
        <ProgressBar
            android:id="@+id/loading"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginTop="15dp" />

    </LinearLayout>
</ScrollView>
