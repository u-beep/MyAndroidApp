<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================ -->
<!-- 主页布局：上方Fragment容器 + 底部导航栏       -->
<!-- 仿微信底部Tab切换                             -->
<!-- ============================================ -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ============================================ -->
    <!-- Fragment 装载区域                            -->
    <!-- 上方占满剩余空间，Fragment 在这里动态替换     -->
    <!-- ============================================ -->
    <FrameLayout
        android:id="@+id/fl_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ============================================ -->
    <!-- 底部导航栏（RadioGroup + RadioButton）        -->
    <!-- orientation="horizontal"：横向排列            -->
    <!-- 每个 RadioButton 占等宽（layout_weight=1）    -->
    <!-- button="@null"：去掉默认圆点图标              -->
    <!-- ============================================ -->
    <RadioGroup
        android:id="@+id/rg_tab"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:elevation="8dp"
        android:paddingTop="@dimen/dp_4"
        android:paddingBottom="@dimen/dp_4">

        <!-- 首页 Tab -->
        <RadioButton
            android:id="@+id/rb_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="首页"
            android:textSize="@dimen/text_12"
            android:textColor="@drawable/tab_text_color"
            android:button="@null"
            android:gravity="center"
            android:checked="true"
            android:drawableTop="@drawable/tab_icon_home" />

        <!-- 用户列表 Tab -->
        <RadioButton
            android:id="@+id/rb_user"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="用户列表"
            android:textSize="@dimen/text_12"
            android:textColor="@drawable/tab_text_color"
            android:button="@null"
            android:gravity="center"
            android:drawableTop="@drawable/tab_icon_user" />

        <!-- 我的 Tab -->
        <RadioButton
            android:id="@+id/rb_mine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="我的"
            android:textSize="@dimen/text_12"
            android:textColor="@drawable/tab_text_color"
            android:button="@null"
            android:gravity="center"
            android:drawableTop="@drawable/tab_icon_mine" />

    </RadioGroup>

</LinearLayout>
