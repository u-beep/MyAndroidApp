<?xml version="1.0" encoding="utf-8"?>
<!-- 根布局：ConstraintLayout约束布局，通过约束关系定位子控件 -->
<!-- 核心规则：每个控件必须给 水平 + 垂直 两个方向的约束 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".LoginActivity">

    <!--
        顶部用户头像（圆形）
        约束方式：水平居中 + 靠上
        layout_width/height = 100dp 固定宽高，保证圆形
        src = 引用 drawable 里的头像图片
        background = circle_head 圆形背景，配合 clipToOutline 裁剪成圆形
        scaleType = centerCrop 等比裁剪填满，头像首选！
        clipToOutline = true 按照背景形状裁剪图片，实现圆形效果
        constraintStart/End = 左右贴着parent → 水平居中
        constraintTop = 顶部贴着parent
        marginTop = 距离顶部30dp
    -->
    <ImageView
        android:id="@+id/iv_head"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/head"
        android:background="@drawable/circle_head"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp" />

    <!--
        标题文字
        约束方式：水平居中 + 在头像下面
        constraintStart/End = 左右贴着parent → 水平居中
        constraintTop = 顶部贴着头像底部（A在B下面 → Top_toBottomOf="@id/B"）
        marginTop = 距离头像20dp
    -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用户登录"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_head"
        android:layout_marginTop="20dp" />

    <!--
        账号输入框
        约束方式：水平铺满 + 在标题下面
        constraintStart/End = 左右贴着parent → 水平铺满
        constraintTop = 顶部贴着标题底部
        marginTop = 距离标题30dp
    -->
    <EditText
        android:id="@+id/et_account"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请输入账号"
        android:padding="12dp"
        android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="30dp" />

    <!--
        密码输入框（带密码显示/隐藏切换）
        TextInputLayout：Material Design 输入框容器，支持尾部图标
        endIconMode="password_toggle"：自动显示眼睛图标，点击切换密码显示/隐藏
        TextInputEditText：放在 TextInputLayout 里面的输入框
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_account"
        android:layout_marginTop="10dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        记住密码勾选框
        约束方式：靠左 + 在密码框下面
        constraintStart = 左边贴着parent（靠左）
        constraintTop = 顶部贴着密码框底部
        marginTop = 距离密码框10dp
    -->
    <CheckBox
        android:id="@+id/cb_remember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="记住密码"
        android:minHeight="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_pwd"
        android:layout_marginTop="10dp" />

    <!--
        登录按钮
        约束方式：水平铺满 + 在记住密码下面
        constraintStart/End = 左右贴着parent → 水平铺满
        constraintTop = 顶部贴着记住密码底部
        marginTop = 距离记住密码20dp
    -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="登录"
        android:backgroundTint="@color/btn_color_selector"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cb_remember"
        android:layout_marginTop="20dp" />

    <!--
        去注册按钮
        约束方式：水平铺满 + 在登录按钮下面
        constraintStart/End = 左右贴着parent → 水平铺满
        constraintTop = 顶部贴着登录按钮底部
        marginTop = 距离登录按钮10dp
    -->
    <Button
        android:id="@+id/btn_to_register"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="去注册"
        android:backgroundTint="#9E9E9E"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_login"
        android:layout_marginTop="10dp" />

    <!--
        修改密码按钮
        约束方式：水平铺满 + 在去注册按钮下面
        constraintStart/End = 左右贴着parent → 水平铺满
        constraintTop = 顶部贴着去注册按钮底部
        marginTop = 距离去注册按钮10dp
    -->
    <Button
        android:id="@+id/btn_to_change_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="修改密码"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_to_register"
        android:layout_marginTop="10dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
