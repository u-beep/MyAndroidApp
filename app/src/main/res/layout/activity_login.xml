<?xml version="1.0" encoding="utf-8"?>
<!-- 根布局：ConstraintLayout约束布局 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".LoginActivity">

    <!-- 头像（圆形） -->
    <ImageView
        android:id="@+id/iv_head"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/head"
        android:background="@drawable/circle_head"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用户登录"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_head"
        android:layout_marginTop="20dp" />

    <!-- 账号输入框（用 Style 简化） -->
    <EditText
        android:id="@+id/et_account"
        style="@style/MyEditText"
        android:layout_width="0dp"
        android:hint="请输入账号"
        android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="30dp" />

    <!-- 密码输入框（用 MyPasswordInput 样式简化） -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_pwd"
        style="@style/MyPasswordInput"
        android:layout_width="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_account">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 记住密码 -->
    <CheckBox
        android:id="@+id/cb_remember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="记住密码"
        android:minHeight="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_pwd"
        android:layout_marginTop="10dp" />

    <!-- 登录按钮（用 MyButton 样式简化） -->
    <Button
        android:id="@+id/btn_login"
        style="@style/MyButton"
        android:layout_width="0dp"
        android:text="登录"
        android:backgroundTint="@color/btn_color_selector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cb_remember"
        android:layout_marginTop="20dp" />

    <!-- 去注册按钮 -->
    <Button
        android:id="@+id/btn_to_register"
        style="@style/MyButton"
        android:layout_width="0dp"
        android:text="去注册"
        android:backgroundTint="#9E9E9E"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_login" />

    <!-- 修改密码按钮 -->
    <Button
        android:id="@+id/btn_to_change_pwd"
        style="@style/MyButton"
        android:layout_width="0dp"
        android:text="修改密码"
        android:backgroundTint="#FF9800"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_to_register" />

    <!--
        加载动画（ProgressBar）
        visibility="gone"：默认隐藏，登录时才显示
        visibility="visible"：显示
    -->
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_to_change_pwd"
        android:layout_marginTop="15dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
