<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================ -->
<!-- 详情页面布局（singleTop启动模式演示）         -->
<!-- 演示5种Intent传值方式的接收                  -->
<!-- ============================================ -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/dp_20">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="@dimen/text_22"
            android:textColor="@color/text_black"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="详情页（singleTop）"
            android:textSize="@dimen/text_25"
            android:textStyle="bold"
            android:textColor="@color/text_black"
            android:gravity="center"
            android:layout_marginEnd="40dp" />

    </LinearLayout>

    <!-- 内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20"
        android:background="@color/bg_card"
        android:padding="@dimen/dp_16">

        <!-- 方式1：putExtra基础类型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="方式1 putExtra基础类型"
            android:textSize="@dimen/text_14"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_extra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:textColor="@color/text_black"
            android:layout_marginTop="@dimen/dp_4" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_12" />

        <!-- 方式2：Bundle打包传参 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="方式2 Bundle打包传参"
            android:textSize="@dimen/text_14"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_bundle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:textColor="@color/text_black"
            android:layout_marginTop="@dimen/dp_4" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_12" />

        <!-- 方式3：Serializable传对象 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="方式3 Serializable传对象"
            android:textSize="@dimen/text_14"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_serializable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:textColor="@color/text_black"
            android:layout_marginTop="@dimen/dp_4" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_12" />

        <!-- 方式4：Parcelable传对象 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="方式4 Parcelable传对象（推荐）"
            android:textSize="@dimen/text_14"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_parcelable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:textColor="@color/text_black"
            android:layout_marginTop="@dimen/dp_4" />

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_12" />

        <!-- 方式5：Application全局变量 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="方式5 Application全局变量"
            android:textSize="@dimen/text_14"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_app_global"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:textColor="@color/text_black"
            android:layout_marginTop="@dimen/dp_4" />

    </LinearLayout>

    <!-- singleTop演示按钮 -->
    <Button
        android:id="@+id/btn_open_again"
        style="@style/MyButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="再次打开详情页（singleTop演示）"
        android:layout_margin="@dimen/dp_20"
        android:backgroundTint="@color/colorOrange"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cornerRadius="12dp" />

</LinearLayout>