<?xml version="1.0" encoding="utf-8"?>
<!-- 修改密码页面布局：ConstraintLayout约束布局，风格与其他页面统一 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".ChangePwdActivity">

    <!--
        旧密码输入框
        hint        = 输入框为空时显示的灰色提示文字
        inputType   = textPassword 输入内容显示成小圆点
        padding     = 内边距12dp
        constraintWidth_percent = 宽度占父布局的90%
    -->
    <EditText
        android:id="@+id/et_old_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请输入旧密码"
        android:inputType="textPassword"
        android:padding="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="120dp" />

    <!--
        新密码输入框
        inputType   = textPassword 输入内容显示成小圆点
        maxLength   = 最多12个字符
    -->
    <EditText
        android:id="@+id/et_new_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请输入新密码"
        android:inputType="textPassword"
        android:maxLength="12"
        android:padding="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_old_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp" />

    <!--
        确认新密码输入框
        inputType   = textPassword 输入内容显示成小圆点
        maxLength   = 最多12个字符
    -->
    <EditText
        android:id="@+id/et_new_pwd2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="请确认新密码"
        android:inputType="textPassword"
        android:maxLength="12"
        android:padding="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_new_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp" />

    <!--
        确认修改按钮
        backgroundTint  = 橙色#FF9800（修改密码用橙色区分其他按钮）
        cornerRadius    = 圆角12dp，与其他按钮风格统一
    -->
    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="确认修改"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_new_pwd2"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
