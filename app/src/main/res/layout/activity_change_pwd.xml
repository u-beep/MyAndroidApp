<?xml version="1.0" encoding="utf-8"?>
<!-- 修改密码页面：ConstraintLayout + Style样式 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/dp_20"
    tools:context=".ChangePwdActivity">

    <!-- 旧密码（用 MyPasswordInput 样式简化） -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_old_pwd"
        style="@style/MyPasswordInput"
        android:layout_width="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="120dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_old_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入旧密码"
            android:inputType="textPassword"
            android:padding="@dimen/dp_12" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 新密码（用 MyPasswordInput 样式简化） -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_new_pwd"
        style="@style/MyPasswordInput"
        android:layout_width="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_old_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="@dimen/dp_20">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_new_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入新密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="@dimen/dp_12" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 确认新密码（用 MyPasswordInput 样式简化） -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_new_pwd2"
        style="@style/MyPasswordInput"
        android:layout_width="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_new_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="@dimen/dp_20">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_new_pwd2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请确认新密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="@dimen/dp_12" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 确认修改按钮（用 MyButton 样式简化） -->
    <Button
        android:id="@+id/btn_confirm"
        style="@style/MyButton"
        android:layout_width="0dp"
        android:text="确认修改"
        android:backgroundTint="@color/colorOrange"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_new_pwd2"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="@dimen/dp_30" />

</androidx.constraintlayout.widget.ConstraintLayout>
