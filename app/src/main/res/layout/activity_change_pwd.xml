<?xml version="1.0" encoding="utf-8"?>
<!-- 修改密码页面布局：ConstraintLayout约束布局 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".ChangePwdActivity">

    <!--
        旧密码输入框（带密码显示/隐藏切换）
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_old_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="120dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_old_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入旧密码"
            android:inputType="textPassword"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        新密码输入框（带密码显示/隐藏切换）
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_new_pwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_old_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_new_pwd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入新密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        确认新密码输入框（带密码显示/隐藏切换）
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_new_pwd2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_new_pwd"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_new_pwd2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请确认新密码"
            android:inputType="textPassword"
            android:maxLength="12"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        确认修改按钮
    -->
    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="确认修改"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        app:cornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_new_pwd2"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginTop="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
